{
  "appId": "com.novasalud.pos",
  "productName": "Nova Salud POS",
  "electronVersion": "42.0.0",
  "electronDist": "../../apps/web-pos/node_modules/electron/dist",
  "directories": {
    "output": "../../dist-electron",
    "app": "../../apps/web-pos"
  },
  "win": {
    "target": "nsis",
    "icon": "../../apps/web-pos/src/assets/logo.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "files": [
    "dist/**/*",
    "!src/**/*",
    "!node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "apps/electron/main.js",
      "to": "main.js"
    },
    {
      "from": "apps/electron/preload.js",
      "to": "preload.js"
    },
    {
      "from": "apps/api",
      "to": "api",
      "filter": ["**/*", "!node_modules/**", "!.env*"]
    },
    {
      "from": "apps/web-pos/dist",
      "to": "web-pos-dist"
    }
  ]
}
