{
  "name": "nova-salud-pos",
  "version": "1.0.0",
  "description": "Nova Salud POS Desktop System",
  "author": "Nova Salud",
  "main": "main.js",
  "build": {
    "appId": "com.novasalud.pos",
    "productName": "Nova Salud POS",
    "electronVersion": "42.0.0",
    "directories": {
      "output": "../../dist-electron",
      "app": "../web-pos"
    },
    "win": {
      "target": "nsis",
      "icon": "../web-pos/public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "electron-preload.cjs",
      "!src/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../api",
        "to": "api"
      }
    ]
  }
}