{
  "name": "web-pos",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Nova Salud POS - Sistema de Punto de Venta",
  "author": "Nova Salud",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -n VITE,API,ELECTRON -c cyan,green,yellow \"vite --port 5173 --strictPort\" \"cd ../api && node src/index.js\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron ../electron/main.js\"",
    "electron:build": "cross-env ELECTRON=true vite build && electron-builder"
  },
  "build": {
    "appId": "com.novasalud.pos",
    "productName": "Nova Salud POS",
    "electronVersion": "42.0.0",
    "directories": {
      "output": "../../dist-electron"
    },
    "win": {
      "target": "portable",
      "icon": "public/favicon.png"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "electron-preload.cjs"
    ],
    "extraResources": [
      {
        "from": "../api",
        "to": "api",
        "filter": ["**/*", "!node_modules/**", "!.env*"]
      }
    ]
  },
  "dependencies": {
    "axios": "^1.16.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
